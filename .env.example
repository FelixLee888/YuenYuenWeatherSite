PORT=4173
AIBOT_BASE_URL=http://127.0.0.1:18789
AIBOT_TIMEOUT_MS=8000

# Comma-separated path candidates (first successful response is used).
AIBOT_DAILY_PATHS=/api/weather/daily,/weather/daily,/api/daily-weather,/api/weather
AIBOT_BENCHMARK_PATHS=/api/weather/benchmark,/weather/benchmark,/api/benchmark
AIBOT_HISTORY_PATHS=/api/weather/history,/weather/history,/api/history
AIBOT_WATCHLIST_GET_PATHS=/api/weather/watchlist,/weather/watchlist,/api/watchlist
AIBOT_WATCHLIST_POST_PATHS=/api/weather/watchlist,/weather/watchlist,/api/watchlist
